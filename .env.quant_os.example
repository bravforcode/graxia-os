# ═══════════════════════════════════════════════════════════════════════════════
# Quant OS — Forex Quantitative Trading System
# Environment Variables Template
# Copy to .env and fill in ALL values before running.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 1: TRADING MODE (CRITICAL — REVIEW CAREFULLY)
# ═══════════════════════════════════════════════════════════════════════════════

# Trading mode — determines risk level and permissions
# PAPER = Simulation only (recommended for testing)
# LIVE_MICRO = Live with micro lots, requires human confirmation
# LIVE_LIMITED = Live with limited position sizes
# LIVE_CONTROLLED = Live with full position sizes
# BACKTEST_ONLY = No live trading, only backtests
TRADING_MODE=PAPER

# Enable live trading — MUST be explicitly set to true for any live mode
# Even in LIVE_MICRO/LIVE_LIMITED, this must be true
# Default is FALSE for safety
LIVE_TRADING_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 2: MT5 BROKER CONNECTION (Required for live trading)
# ═══════════════════════════════════════════════════════════════════════════════

# MetaTrader 5 credentials
MT5_LOGIN=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=ICMarketsSC-Demo

# MT5 installation path (Windows default shown)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Connection timeout in milliseconds
MT5_TIMEOUT_MS=10000

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3: DATABASE & REDIS
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL database URL
DATABASE_URL=postgresql+asyncpg://graxia:changeme@localhost:5432/graxia_quant_os

# Redis for caching, idempotency, and real-time data
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 4: SECURITY (CRITICAL — USE STRONG KEYS)
# ═══════════════════════════════════════════════════════════════════════════════

# JWT secret for API authentication
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_64_char_hex_string_minimum_32_chars_long_for_security

# HMAC secret for TradingView webhook authentication
# Generate: openssl rand -hex 32
WEBHOOK_HMAC_SECRET=change_this_for_webhook_hmac_verification_32_chars_min

# Admin API key for administrative endpoints
# Generate: openssl rand -hex 32
ADMIN_API_KEY=change_this_admin_key_for_emergency_operations_32_chars

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 5: TELEGRAM NOTIFICATIONS (Optional but recommended)
# ═══════════════════════════════════════════════════════════════════════════════

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Telegram Chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 6: RISK LIMITS (Soft limits — can be adjusted)
# ═══════════════════════════════════════════════════════════════════════════════

# Max risk per trade (default 1%, max 1% hard limit)
RISK_PER_TRADE_PCT=1.0

# Max daily loss before kill switch triggers (default 2%)
MAX_DAILY_LOSS_PCT=2.0

# Max drawdown before kill switch triggers (default 10%, hard stop at 15%)
MAX_DRAWDOWN_PCT=10.0

# Max open positions (default 5, max 10 hard limit)
MAX_POSITIONS=5

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 7: PAPER TRADING SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Starting capital for paper trading (default $10,000)
PAPER_INITIAL_CAPITAL=10000.0

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 8: LIVE MICRO SETTINGS (Extra cautious mode)
# ═══════════════════════════════════════════════════════════════════════════════

# Max position size in micro mode ($1,000 default)
MICRO_MAX_POSITION_SIZE=1000.0

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 9: API SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Webhook host and port
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PATH=/api/v1/webhook/tradingview

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 10: MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Prometheus metrics port
PROMETHEUS_PORT=9090

# Health check interval in seconds
HEALTH_CHECK_INTERVAL_SECONDS=30

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 11: STRATEGY SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Ensemble confidence threshold (0.60 = 60%)
ENSEMBLE_CONFIDENCE_THRESHOLD=0.60

# ML model confidence threshold
ML_MIN_CONFIDENCE=0.65

# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 12: LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════════
# 🚨 SAFETY CHECKLIST BEFORE GOING LIVE 🚨
# ═══════════════════════════════════════════════════════════════════════════════
# 
# [ ] TRADING_MODE is set to your desired mode (PAPER for testing)
# [ ] LIVE_TRADING_ENABLED is false (unless you want live trading)
# [ ] MT5_LOGIN, MT5_PASSWORD, MT5_SERVER are correct
# [ ] All security keys are strong (32+ chars, random hex)
# [ ] TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are set for alerts
# [ ] DATABASE_URL points to correct database
# [ ] REDIS_URL is accessible
# [ ] You've tested in PAPER mode for at least 60 days
# [ ] You've verified kill switch works (test trigger/reset)
# [ ] You've verified Telegram notifications work
# [ ] You have a backup plan if systems fail
# 
# ═══════════════════════════════════════════════════════════════════════════════
