# PERSONAL OS — Example Environment File
#
# Copy this file to .env and fill in your secrets locally.
# Do NOT commit your real secrets.
#

# ── Core ────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Auth/Security ───────────────────────────────────────
ADMIN_DEFAULT_EMAIL=admin@local
ADMIN_DEFAULT_PASSWORD=change_me
SECRET_KEY=change_me
ENCRYPTION_KEY=change_me
API_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database/Redis ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_MIGRATION_URL=postgresql://user:pass@host:5432/dbname
REQUIRE_SUPABASE=false
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLLING_ENABLED=true

# ── Google Workspace ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_WORKSPACE_EMAIL=
GOOGLE_ENABLE_WRITE_SCOPES=false

# ── AI Providers (optional) ─────────────────────────────
# Local OpenClaw gateway OR OpenRouter OpenAI-compatible API.
OPENCLAW_API_KEY=
OPENCLAW_BASE_URL=https://openrouter.ai/api/v1
OPENCLAW_DEFAULT_MODEL=openrouter/free
OPENCLAW_FAST_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENCLAW_FALLBACK_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemma-3-12b-it:free,qwen/qwen3-next-80b-a3b-instruct:free

GEMINI_API_KEY=
GEMINI_DAILY_REQUEST_LIMIT=1400
MODEL_ROUTING_ENABLED=true
DEFAULT_MODEL=
FAST_MODEL=

# ── Search / Lead Sources ───────────────────────────────
SERPAPI_KEY=

# ── Obsidian ────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=
OBSIDIAN_ROOT_FOLDER=Second Brain
OBSIDIAN_AUTO_BOOTSTRAP=true
OBSIDIAN_AUTO_SYNC_ENABLED=true
OBSIDIAN_API_URL=http://localhost:27123
OBSIDIAN_API_KEY=
OBSIDIAN_API_VERIFY_SSL=true

# ── Outreach ────────────────────────────────────────────
OUTREACH_AUTOSEND_ENABLED=false
OUTREACH_ALLOWED_EMAILS=
OUTREACH_ALLOWED_DOMAINS=
OUTREACH_MAX_PER_DAY=5
OUTREACH_MIN_DAYS_BETWEEN_CONTACT=14
OUTREACH_FROM_EMAIL=
OUTREACH_CAMPAIGN_NAME=revenue-first

EMAIL_TRACKING_ENABLED=true
TRACKING_BASE_URL=http://localhost:8000
TRACKING_SIGNING_SECRET=

# ── Leadgen ─────────────────────────────────────────────
LEADGEN_ENABLED=false
LEADGEN_MAX_PER_RUN=50
LEADGEN_EXPORT_DIR=data/leads
LEADGEN_USE_SERPAPI=false
LEADGEN_SERPAPI_MAX_QUERIES=8
LEADGEN_SERPAPI_RESULTS_PER_QUERY=10

# ── ICP ────────────────────────────────────────────────
ICP_INDUSTRIES=software,SaaS,startup,e-commerce,retail,marketplace,healthcare,clinic,hospital,manufacturing,logistics,fintech,edtech,proptech,services
ICP_COMPANY_SIZE_RANGE=1-5000
ICP_COUNTRIES=GLOBAL
ICP_TITLES=Founder,CEO,COO,CTO,CIO,Head of Operations,Operations Manager,RevOps,CRM Manager,Product Manager,Engineering Manager
ICP_KEYWORDS=automation,workflow,operations,integrations,CRM,HubSpot,Salesforce,reporting,dashboard,lead-gen,follow-up

# ── CRM Sync (optional) ─────────────────────────────────
HUBSPOT_PRIVATE_APP_TOKEN=
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=
