# GRAXIA OS - Environment Configuration for CPX11 (2GB RAM)
# Copy to .env.production and fill in your values
# This template matches backend/app/config.py exactly

# ============================================
# APP CONFIGURATION
# ============================================
APP_ENV=production
APP_HOST=your-domain.com
APP_BASE_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# Logging (minimal for low memory)
LOG_LEVEL=WARNING
LOG_FORMAT=json

# Security - MUST be changed for production!
SECRET_KEY=change-me-min-32-chars-long-secret-key-here
ENCRYPTION_KEY=change-me-encryption-key
CSRF_SECRET=change-me-csrf-secret
API_KEY=change-me-api-key

# ============================================
# DATABASE (Supabase - external, not on VPS)
# ============================================
# Supabase credentials (get from Supabase dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database URL - Supabase connection pooler
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:[password]@aws-0-ap-southeast-1.pooler.supabase.co:5432/postgres?sslmode=require

# ============================================
# REDIS (Internal on VPS via Docker)
# ============================================
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# AI/LLM CONFIGURATION
# ============================================
# OpenClaw (Primary - Claude via proxy)
OPENCLAW_API_KEY=your-openclaw-key
OPENCLAW_BASE_URL=https://api.openclaw.ai/v1
OPENCLAW_DEFAULT_MODEL=claude-sonnet-4-5
OPENCLAW_FAST_MODEL=claude-haiku-4-5

# Gemini (Free tier available)
GEMINI_API_KEY=your-gemini-key

# Cost limits (critical for 24/7 operation - prevents bill shock)
MAX_DAILY_REQUESTS=1400
MAX_DAILY_AI_COST_USD=2.00
MAX_MONTHLY_AI_COST_USD=30.00

# ============================================
# MONITORING & ALERTS
# ============================================
# Telegram for alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=your-bot-token:token-hash
TELEGRAM_CHAT_ID=your-chat-id-number
TELEGRAM_POLLING_ENABLED=false

ALERTMANAGER_WEBHOOK_TOKEN=generate-random-webhook-token

# ============================================
# BACKUP
# ============================================
BACKUP_DIR=/app/backups
BACKUP_BUCKET=
BACKUP_REGION=
BACKUP_ENDPOINT=
BACKUP_PREFIX=backups
BACKUP_ENCRYPTION_PUBLIC_KEY=
BACKUP_ENCRYPTION_PRIVATE_KEY_FILE=

# ============================================
# WORKER CONFIGURATION (Optimized for 2GB RAM)
# ============================================
SCHEDULER_EMBEDDED=true

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# ADMIN SEED
# ============================================
ADMIN_DEFAULT_EMAIL=admin@your-domain.com
ADMIN_DEFAULT_PASSWORD=change-me-strong-password

# ============================================
# EXTERNAL INTEGRATIONS (Optional)
# ============================================
# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_WORKSPACE_EMAIL=

# HubSpot
HUBSPOT_PRIVATE_APP_TOKEN=

# Salesforce
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=

# SerpAPI (for lead generation)
SERPAPI_KEY=

# ============================================
# REVENUE / OUTREACH (Optional)
# ============================================
DAILY_REVENUE_TARGET_THB=1000
OUTREACH_FROM_EMAIL=noreply@your-domain.com
TRACKING_BASE_URL=https://your-domain.com
TRACKING_SIGNING_SECRET=change-me-signing-secret
