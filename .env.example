# ──────────────────────────────────────────────────────────────────────────────
# Graxia Revenue OS — Environment Variables
# Copy to .env and fill in all values before running.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Security Secrets (REQUIRED IN PRODUCTION & DEVELOPMENT) ───────────────────
# These secrets MUST be configured before starting the application.
# The application will refuse to start if these are missing or look like placeholders
# (except in testing mode where defaults are provided automatically).
#
# Generate strong secrets using these commands:
#   SECRET_KEY:        openssl rand -hex 32
#   ENCRYPTION_KEY:    openssl rand -hex 32
#   POSTGRES_PASSWORD: openssl rand -base64 32
#
# Minimum requirements:
#   - SECRET_KEY: 32+ characters, high entropy (used for JWT signing)
#   - ENCRYPTION_KEY: 32+ characters (used for data encryption)
#   - POSTGRES_PASSWORD: 16+ characters (database access)
#
# IMPORTANT: Never use placeholder values like "changeme", "development-secret", etc.
# The validator will detect and reject these patterns.

# REQUIRED: JWT signing key (minimum 32 characters, 64+ recommended for production)
SECRET_KEY=

# REQUIRED: Data encryption key (minimum 32 characters)
ENCRYPTION_KEY=

# REQUIRED: Database password (minimum 16 characters)
# Note: This is used in DATABASE_URL below
POSTGRES_PASSWORD=

# ── Graxia OS (Optional) ──────────────────────────────────────────────────
GRAXIA_ENABLED=false
# USE_SQLITE_FALLBACK=true  # Local dev only when Postgres is unavailable. NEVER in production.
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# ── Runtime mode ──────────────────────────────────────────────────────────────
# Options: development | staging | production
# In production, missing ADMIN_API_KEY or STRIPE_WEBHOOK_SECRET raises RuntimeError at startup.
APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver required (postgresql+asyncpg://)
# IMPORTANT: Replace 'changeme' with the POSTGRES_PASSWORD you generated above
DATABASE_URL=postgresql+asyncpg://graxia:REPLACE_WITH_POSTGRES_PASSWORD@localhost:5432/graxia_revenue_os

# ── API Security ──────────────────────────────────────────────────────────────
# All /api/* admin routes require: X-Admin-Api-Key: <value>
ADMIN_API_KEY=change-this-in-production-min-32-chars

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_change_this_in_production

# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Email delivery (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_change_this_in_production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Requests per minute per IP (burst = short-window allowance above limit)
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20

# ── Internal Monitoring ───────────────────────────────────────────────────────
# Token required to access /metrics endpoint. Generate: openssl rand -hex 32
INTERNAL_METRICS_TOKEN=

# ── Alertmanager Webhook ─────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION: Set ALERTMANAGER_WEBHOOK_SECRET for HMAC-SHA256 signature verification.
# This prevents webhook spoofing and replay attacks.
#
# Generate a strong secret:
#   openssl rand -hex 32
#
# Configure Alertmanager to send these headers:
#   X-Alertmanager-Signature: sha256=<hmac_signature>
#   X-Graxia-Timestamp: <unix_timestamp>
#
# Signature format: sha256=HMAC-SHA256(secret, "{timestamp}.{body}")
# Timestamp window: ±5 minutes (prevents replay attacks)
#
# Example Alertmanager webhook_configs:
#   webhook_configs:
#     - url: 'https://api.graxia.com/api/v1/integrations/alerts/telegram'
#       http_config:
#         authorization:
#           credentials: 'your-webhook-secret-here'
#
ALERTMANAGER_WEBHOOK_SECRET=

# DEPRECATED: Legacy bearer-token authentication (used only when SECRET is not set)
# Will be removed in future versions. Migrate to HMAC signature verification.
ALERTMANAGER_WEBHOOK_TOKEN=

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Optional: Sentry DSN for error tracking and monitoring
SENTRY_DSN=

# ── Event Bus Configuration ───────────────────────────────────────────────────
# Maximum time to wait for event processing to complete during shutdown (seconds)
# Default: 30 seconds
# Increase this value if you have long-running event handlers that need more time
# to complete gracefully during application shutdown.
EVENT_BUS_SHUTDOWN_TIMEOUT=30

# Maximum queue size for event bus (prevents memory exhaustion)
# Default: 10000 events
# When queue is full, new events will be dropped or blocked (backpressure)
EVENT_BUS_MAX_QUEUE_SIZE=10000

# ── CSRF Configuration ────────────────────────────────────────────────────────
# CSRF token expiry time in hours
# Default: 1 hour
# Tokens older than this will be rejected
CSRF_TOKEN_EXPIRY_HOURS=1

# ── Model Router Configuration ────────────────────────────────────────────────
# Task defaults for model router (tier, budget_tag, default_tokens)
# Format: "task_class:tier,budget_tag,tokens;..."
# Example: "classification:cheap,low,300;analysis:mid,standard,800"
ROUTER_TASK_DEFAULTS="classification:cheap,low,300;triage:cheap,low,400;short_summary:cheap,low,450;analysis:mid,standard,800;short_draft:mid,standard,700;meeting_summary:mid,standard,800;proposal:high,high,1600;strategy:high,high,1200"

# ── Security Headers Configuration ────────────────────────────────────────────
# Content Security Policy (CSP)
# Customize per environment (development, staging, production)
SECURITY_HEADERS_CSP="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

# HTTP Strict Transport Security (HSTS) max age in seconds
# Default: 63072000 (2 years)
SECURITY_HEADERS_HSTS_MAX_AGE=63072000

# X-Frame-Options header value
# Options: DENY, SAMEORIGIN, ALLOW-FROM uri
SECURITY_HEADERS_FRAME_OPTIONS="DENY"

# X-Content-Type-Options header value
SECURITY_HEADERS_CONTENT_TYPE_OPTIONS="nosniff"

# Referrer-Policy header value
SECURITY_HEADERS_REFERRER_POLICY="strict-origin-when-cross-origin"

# Permissions-Policy header value
SECURITY_HEADERS_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=(), payment=(), usb=()"

# X-DNS-Prefetch-Control header value
SECURITY_HEADERS_DNS_PREFETCH_CONTROL="off"
