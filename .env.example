# ═══════════════════════════════════════
# PERSONAL SOVEREIGN OS — ENVIRONMENT
# ═══════════════════════════════════════
# Copy to .env and fill in your values

# ── Security ──────────────────────────
SECRET_KEY=development-secret-key-change-me
ENCRYPTION_KEY=
API_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend:5173
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
APP_HOST=localhost
CADDY_EMAIL=admin@example.com

# ── Database ──────────────────────────
POSTGRES_DB=personal_os
POSTGRES_USER=personal_os
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://personal_os:changeme_in_production@postgres:5432/personal_os
DATABASE_MIGRATION_URL=
REQUIRE_SUPABASE=false
# Supabase example:
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_MIGRATION_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
# For long-running backend/celery prefer Direct connection or Supavisor Session mode (5432).
# Transaction mode on 6543 is supported with NullPool, but less ideal for always-on workers.

# ── Redis ─────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
REDIS_PASSWORD=

# ── AI — OpenClaw (Primary) ────────────
# Get API key at: https://openclaw.ai/
OPENCLAW_API_KEY=your_openclaw_api_key_here
OPENCLAW_BASE_URL=https://api.openclaw.ai/v1
OPENCLAW_DEFAULT_MODEL=claude-sonnet-4-5
OPENCLAW_FAST_MODEL=claude-haiku-4-5

# ── AI — Gemini (Fallback / Free tier) ─
# Get free API key at: https://aio.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_MODEL=claude-sonnet-4-5
FAST_MODEL=claude-haiku-4-5
GEMINI_DAILY_REQUEST_LIMIT=1400
MODEL_ROUTING_ENABLED=true
CHEAP_MODEL=claude-haiku-4-5
MID_MODEL=claude-sonnet-4-5
HIGH_QUALITY_MODEL=claude-sonnet-4-5
CHEAP_MODEL_MAX_TOKENS=500
MID_MODEL_MAX_TOKENS=1200
HIGH_QUALITY_MODEL_MAX_TOKENS=2000
CHEAP_MODEL_INPUT_COST_PER_1M=0.25
CHEAP_MODEL_OUTPUT_COST_PER_1M=1.25
MID_MODEL_INPUT_COST_PER_1M=3.0
MID_MODEL_OUTPUT_COST_PER_1M=15.0
HIGH_QUALITY_MODEL_INPUT_COST_PER_1M=3.0
HIGH_QUALITY_MODEL_OUTPUT_COST_PER_1M=15.0
ROUTER_SIMPLE_MAX_COMPLEXITY=2
ROUTER_MEDIUM_MAX_COMPLEXITY=6
MAX_SINGLE_LLM_CALL_COST_USD=0.10

# ── Telegram ──────────────────────────
# 1. Message @BotFather on Telegram to create a bot
# 2. Get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_POLLING_ENABLED=false

# ── Google Workspace (optional but recommended) ───────
# OAuth app with Gmail + Calendar read scopes and a refresh token for your own account.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_WORKSPACE_EMAIL=you@example.com

# ── SerpAPI (optional, 100 free/month) ─
# Get free key at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# ── Obsidian Integration ──────────────
# Path to your Obsidian vault (e.g., C:\Users\YourName\Documents\ObsidianVault\Second Brain)
OBSIDIAN_VAULT_PATH=C:\Users\menum\Documents\ObsidianVault\Second Brain
# Root folder inside that vault used for the shared second-brain system
OBSIDIAN_ROOT_FOLDER=
# Auto-bootstrap the vault scaffold on backend startup
OBSIDIAN_AUTO_BOOTSTRAP=true
# Auto-sync opportunities, submissions, contacts, tasks, and knowledge into Obsidian
OBSIDIAN_AUTO_SYNC_ENABLED=true
# Optional: Obsidian Local REST API plugin URL
OBSIDIAN_API_URL=http://localhost:27123
OBSIDIAN_API_KEY=

# ── n8n ───────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme_in_production

# ── App Settings ──────────────────────
APP_ENV=development
LOG_LEVEL=INFO
IDENTITY_PATH=/identity/profile.yaml

# ── Cost Controls ─────────────────────
# Daily request limit for Gemini (free tier: 1500/day, use 1400 for safety)
MAX_DAILY_REQUESTS=1400
MAX_DAILY_AI_COST_USD=2.00
MAX_MONTHLY_AI_COST_USD=30.00
MAX_OUTREACH_PER_DAY=5
MAX_PENDING_APPROVALS=10
