# ──────────────────────────────────────────────────────────────────────────────
# Graxia Revenue OS — Environment Variables
# COPY THIS TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env TO VERSION CONTROL
# ──────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Security Keys ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-min-64-chars
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# ── REQUIRED: Database ────────────────────────────────────────────────────────
# asyncpg driver required (postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/graxia_dev

# ── App Configuration ─────────────────────────────────────────────────────────
APP_ENV=development

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Supabase (optional for local dev) ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20

# ── Security Headers (production only) ────────────────────────────────────────
# SECURITY_HEADERS_CSP=default-src 'self';
# SECURITY_HEADERS_HSTS_MAX_AGE=63072000
# SECURITY_HEADERS_FRAME_OPTIONS=DENY

# ── Staging Configuration ─────────────────────────────────────────────────────
# APP_ENV=staging
# ENABLE_MOCK_AUTH=true
# STAGING_REQUIRE_AUTH=true
# LOCAL_DEV_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
# ALLOWED_ORGANIZATION_IDS=
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=60
# PUBLIC_RATE_LIMIT_REQUESTS_PER_MINUTE=20
# MCP_RATE_LIMIT_REQUESTS_PER_MINUTE=30
# STRIPE_MODE=test
# STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
# STRIPE_WEBHOOK_SECRET=whsec_test_PLACEHOLDER
# EMAIL_PROVIDER=mock
# ALLOW_REAL_EMAIL_SEND=false
# GOOGLE_WORKSPACE_PROVIDER=mock
# ALLOW_REAL_GOOGLE_MUTATION=false
# ALLOW_REAL_LLM_CALLS=false
# LOG_LEVEL=INFO
# STRUCTURED_LOGGING=true
