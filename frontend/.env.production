# Frontend production environment variables
# Generated by production setup — update these values before deploying

# API endpoint: must point to your production domain, not localhost
# Used by Vite at build time and server-side rendering at runtime
VITE_API_BASE_URL=https://your-domain.com/api/v1

# WebSocket streaming endpoint for agent event streams
VITE_AGENT_STREAM_URL=wss://your-domain.com/api/v1/events/stream
