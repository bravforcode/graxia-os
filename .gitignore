# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# Env
.env
.env.production
.env.backup-*
.env.bak*
*.env.local
secrets/
# Exception: frontend build vars (VITE_*) are NOT secrets — safe to track
# Real secrets live in root .env.production (which stays gitignored)
!frontend/.env.production

# Docker
.docker/

# Database
*.db
*.sqlite

# IDE
.vscode/
.idea/
*.swp
*.swo
.claude/
.codex/
settings.local.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
dump.rdb

# Alembic migration files MUST be version-controlled!
# Removing them from .gitignore ensures schema migrations run on every deploy.
# DO NOT re-add alembic/versions/*.py here.
# Only .gitkeep is excluded (it's a placeholder for the empty directory).
!alembic/versions/.gitkeep

# Git Worktrees
.worktrees/
node_modules

# Backend local artifacts / secrets
backend/.coverage
backend/.venv/
backend/celerybeat-schedule*
backend/staging-token.json
backend/openapi.json
backend/error.log
backend/uvicorn-local*.log
backend/test-results/
backend/backups/
backend/.tmp_pytest/
backend/tmp*/
backend/C*/

.vercel
