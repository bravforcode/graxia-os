# ══════════════════════════════════════════════════════════════════════
# Quant OS — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════

# ── MT5 Broker ──────────────────────────────────────────────────────
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=Pepperstone-Demo
MT5_TIMEOUT_MS=15000

# ── FRED API (economic data) ────────────────────────────────────────
FRED_API_KEY=

# ── Webhook ──────────────────────────────────────────────────────────
TV_WEBHOOK_SECRET=
ADMIN_API_KEY=

# ── Telegram Alerts ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quant_os
REDIS_URL=

# ── Trading ──────────────────────────────────────────────────────────
TRADING_MODE=paper
MAX_RISK_PER_TRADE_PCT=0.5

# ── API Server ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Observability ────────────────────────────────────────────────────
SENTRY_DSN=
LOKI_URL=
LOKI_TENANT_ID=
