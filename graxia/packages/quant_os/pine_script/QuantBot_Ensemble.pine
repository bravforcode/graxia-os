//@version=5
strategy(
    title          = "QuantBot v3.0 — Ensemble (MTM + MRB)",
    overlay        = true,
    margin_long    = 100,
    margin_short   = 100,
    calc_on_every_tick = false,
    process_orders_on_close = true,
    default_qty_type = strategy.fixed,
    default_qty_value = 0.01
)

// ═══════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════
grp_ema   = "EMA Settings"
ema_fast  = input.int(9,   "EMA Fast",   group=grp_ema)
ema_mid   = input.int(20,  "EMA Mid",    group=grp_ema)
ema_slow  = input.int(50,  "EMA Slow",   group=grp_ema)
ema_trend = input.int(200, "EMA Trend",  group=grp_ema)

grp_rsi   = "RSI Settings"
rsi_len   = input.int(14,  "RSI Length", group=grp_rsi)
rsi_long  = input.int(52,  "RSI Long Min", group=grp_rsi)
rsi_short = input.int(48,  "RSI Short Max", group=grp_rsi)

grp_bb    = "Bollinger Bands"
bb_len    = input.int(20,  "BB Length",  group=grp_bb)
bb_mult   = input.float(2.0,"BB StdDev", group=grp_bb)

grp_atr   = "ATR & Risk"
atr_len   = input.int(14,  "ATR Length", group=grp_atr)
sl_mult   = input.float(1.5,"SL ATR Mult", group=grp_atr)
tp_mult   = input.float(3.0,"TP ATR Mult", group=grp_atr)
vol_mult  = input.float(1.2,"Volume Mult Filter", group=grp_atr)

grp_htf   = "Higher Timeframe"
h1_tf     = input.timeframe("60",  "H1 Timeframe", group=grp_htf)
h4_tf     = input.timeframe("240", "H4 Timeframe", group=grp_htf)

grp_alert = "Webhook Settings"
webhook_url = input.string("https://your-vps.com/api/v1/webhook/tradingview", "Webhook URL", group=grp_alert)
hmac_secret = input.string("", "HMAC Secret", group=grp_alert)

// ═══════════════════════════════════════════════════════════
// INDICATORS
// ═══════════════════════════════════════════════════════════
[ema_f, ema_m, ema_s, ema_t] = [
    ta.ema(close, ema_fast),
    ta.ema(close, ema_mid),
    ta.ema(close, ema_slow),
    ta.ema(close, ema_trend)
]

rsi     = ta.rsi(close, rsi_len)
atr     = ta.atr(atr_len)
bb      = ta.bb(close, bb_len, bb_mult)
bb_u    = bb[0]  // Upper band
bb_m    = bb[1]  // Middle band  
bb_l    = bb[2]  // Lower band

stoch_k = ta.stoch(close, high, low, 14)
vol_sma = ta.sma(volume, 20)

// ADX proxy using smoothed directional movement
adx_val = ta.rma(math.abs(ta.change(ta.ema(close, 14))), 14)

// Higher Timeframe data
h4_ema200 = request.security(syminfo.tickerid, h4_tf, ta.ema(close, 200))
h1_ema200 = request.security(syminfo.tickerid, h1_tf, ta.ema(close, 200))
h4_rsi    = request.security(syminfo.tickerid, h4_tf, ta.rsi(close, 14))
h1_adx    = request.security(syminfo.tickerid, h1_tf, ta.rma(math.abs(ta.change(ta.ema(close, 14))), 14))

// ═══════════════════════════════════════════════════════════
// REGIME DETECTION
// ═══════════════════════════════════════════════════════════
is_trending  = h4_rsi > 55 or h4_rsi < 45
is_ranging   = not is_trending and h1_adx < 0.001

// ═══════════════════════════════════════════════════════════
// STRATEGY 1: MULTI-TIMEFRAME MOMENTUM (MTM)
// ═══════════════════════════════════════════════════════════
mtm_long_cond = (
    close > h4_ema200 and              // H4 Regime: Bullish
    close > h1_ema200 and              // H1 Trend: Up
    ta.crossover(ema_f, ema_m) and     // M15 Entry: Fast cross Mid
    close > ema_t and                  // Above 200 EMA
    rsi > rsi_long and                 // RSI momentum confirm
    volume > vol_sma * vol_mult        // Volume confirm
)

mtm_short_cond = (
    close < h4_ema200 and
    close < h1_ema200 and
    ta.crossunder(ema_f, ema_m) and
    close < ema_t and
    rsi < rsi_short and
    volume > vol_sma * vol_mult
)

// ═══════════════════════════════════════════════════════════
// STRATEGY 2: MEAN REVERSION BOLLINGER (MRB)
// ═══════════════════════════════════════════════════════════
// Only trade in ranging markets with ADX < 25
mrb_long_cond  = is_ranging and close < bb_l and stoch_k < 20 and rsi < 35
mrb_short_cond = is_ranging and close > bb_u and stoch_k > 80 and rsi > 65

// ═══════════════════════════════════════════════════════════
// ENSEMBLE SIGNAL LOGIC
// ═══════════════════════════════════════════════════════════
// MTM has priority in trending markets
// MRB only activates in ranging markets

long_signal  = mtm_long_cond  or mrb_long_cond
short_signal = mtm_short_cond or mrb_short_cond

// Prevent conflicting signals
if long_signal and short_signal
    long_signal  := false
    short_signal := false

// ═══════════════════════════════════════════════════════════
// DYNAMIC SL/TP CALCULATION
// ═══════════════════════════════════════════════════════════
sl_dist = atr * sl_mult
tp_dist = atr * tp_mult

long_sl  = close - sl_dist
long_tp  = close + tp_dist
short_sl = close + sl_dist
short_tp = close - tp_dist

// ═══════════════════════════════════════════════════════════
// POSITION SIZING (Risk-Based)
// ═══════════════════════════════════════════════════════════
// Calculate position size based on 1% risk per trade
account_balance = strategy.equity
risk_pct = 1.0
risk_amount = account_balance * (risk_pct / 100)

price_risk_long = close - long_sl
price_risk_short = short_sl - close

// Standard lot size calculation (100,000 units per lot for forex)
// For XAUUSD (Gold), adjust accordingly
lot_size = syminfo.type == "forex" ? 100000 : 1

long_lots = price_risk_long > 0 ? (risk_amount / price_risk_long) / lot_size : 0.01
short_lots = price_risk_short > 0 ? (risk_amount / price_risk_short) / lot_size : 0.01

// ═══════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════
if long_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long, qty=long_lots)
    strategy.exit("Long Exit", "Long", stop=long_sl, limit=long_tp)
    
    strategy_name = mtm_long_cond ? "mtm" : "mrb"
    regime_str    = is_trending ? "trend" : "range"
    
    // Build alert message for webhook
    alert_msg = '{"action":"buy","symbol":"' + syminfo.ticker + 
                '","price":' + str.tostring(close, "#.#####") +
                ',"sl":' + str.tostring(long_sl, "#.#####") +
                ',"tp":' + str.tostring(long_tp, "#.#####") +
                ',"strategy":"' + strategy_name + 
                '","regime":"' + regime_str + 
                '","atr":' + str.tostring(atr, "#.#####") +
                ',"lots":' + str.tostring(long_lots, "#.##") +
                ',"timestamp":' + str.tostring(timenow)
                + '}'
    
    alert(alert_msg, alert.freq_once_per_bar)

if short_signal and strategy.position_size == 0
    strategy.entry("Short", strategy.short, qty=short_lots)
    strategy.exit("Short Exit", "Short", stop=short_sl, limit=short_tp)
    
    strategy_name = mtm_short_cond ? "mtm" : "mrb"
    regime_str    = is_trending ? "trend" : "range"
    
    alert_msg = '{"action":"sell","symbol":"' + syminfo.ticker + 
                '","price":' + str.tostring(close, "#.#####") +
                ',"sl":' + str.tostring(short_sl, "#.#####") +
                ',"tp":' + str.tostring(short_tp, "#.#####") +
                ',"strategy":"' + strategy_name + 
                '","regime":"' + regime_str + 
                '","atr":' + str.tostring(atr, "#.#####") +
                ',"lots":' + str.tostring(short_lots, "#.##") +
                ',"timestamp":' + str.tostring(timenow)
                + '}'
    
    alert(alert_msg, alert.freq_once_per_bar)

// ═══════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════
plot(ema_f, "EMA Fast",  color=color.new(color.blue,  0), linewidth=1)
plot(ema_m, "EMA Mid",   color=color.new(color.orange, 0), linewidth=1)
plot(ema_s, "EMA Slow",  color=color.new(color.red,   0), linewidth=2)
plot(ema_t, "EMA Trend", color=color.new(color.gray,  30), linewidth=2)
plot(bb_u,  "BB Upper",  color=color.new(color.purple, 40))
plot(bb_l,  "BB Lower",  color=color.new(color.purple, 40))

// Background color for signals
bgcolor(long_signal  ? color.new(color.green, 92) : na)
bgcolor(short_signal ? color.new(color.red,   92) : na)

// Signal labels
plotshape(long_signal,  "Buy Signal",  shape.labelup,   location.belowbar, color.green, text="BUY",  textcolor=color.white, size=size.small)
plotshape(short_signal, "Sell Signal", shape.labeldown, location.abovebar, color.red,   text="SELL", textcolor=color.white, size=size.small)

// Regime indicator
table_regime = table.new(position.top_right, 1, 1, bgcolor=color.black, frame_width=1)
regime_text = is_trending ? "📈 TREND" : "📊 RANGE"
regime_color = is_trending ? color.green : color.blue
table.cell(table_regime, 0, 0, regime_text, text_color=regime_color, text_size=size.small)

// ═══════════════════════════════════════════════════════════
// INFO PANEL
// ═══════════════════════════════════════════════════════════
var info_table = table.new(position.bottom_left, 2, 5, bgcolor=color.black, frame_width=1)

if barstate.islast
    table.cell(info_table, 0, 0, "Regime:", text_color=color.gray, text_size=size.tiny)
    table.cell(info_table, 1, 0, is_trending ? "Trending" : "Ranging", text_color=is_trending ? color.green : color.blue, text_size=size.tiny)
    
    table.cell(info_table, 0, 1, "ATR:", text_color=color.gray, text_size=size.tiny)
    table.cell(info_table, 1, 1, str.tostring(atr, "#.#####"), text_color=color.white, text_size=size.tiny)
    
    table.cell(info_table, 0, 2, "RSI:", text_color=color.gray, text_size=size.tiny)
    table.cell(info_table, 1, 2, str.tostring(rsi, "#"), text_color=rsi > 50 ? color.green : color.red, text_size=size.tiny)
    
    table.cell(info_table, 0, 3, "Position:", text_color=color.gray, text_size=size.tiny)
    pos_text = strategy.position_size > 0 ? "Long" : strategy.position_size < 0 ? "Short" : "Flat"
    pos_color = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(info_table, 1, 3, pos_text, text_color=pos_color, text_size=size.tiny)
    
    table.cell(info_table, 0, 4, "Equity:", text_color=color.gray, text_size=size.tiny)
    table.cell(info_table, 1, 4, "$" + str.tostring(strategy.equity, "#,###.##"), text_color=color.white, text_size=size.tiny)
