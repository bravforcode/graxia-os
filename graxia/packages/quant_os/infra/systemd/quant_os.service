[Unit]
Description=Quant OS Trading Bot
After=network.target

[Service]
Type=simple
User=quant_os
WorkingDirectory=/opt/quant_os
EnvironmentFile=/opt/quant_os/.env
ExecStart=/opt/quant_os/.venv/bin/python -m uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
