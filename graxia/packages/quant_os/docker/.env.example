# Graxia Trading System — Environment Variables
# Copy to .env and fill secrets. NEVER commit .env to git.
#   cp .env.example .env && nano .env

TRADING_MODE=PAPER
LIVE_TRADING_ENABLED=false
LOG_LEVEL=INFO

DB_USER=graxia
DB_NAME=quant_os

# Generate secrets:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
DB_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
JWT_SECRET_KEY=CHANGE_ME
WEBHOOK_HMAC_SECRET=CHANGE_ME
ADMIN_API_KEY=CHANGE_ME

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
