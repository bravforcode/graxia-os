# Graxia OS - Fly.io Production Environment Template
# Copy this to .env and fill in your actual values
# Then set secrets via: fly secrets set --app graxia-api $(cat .env | xargs)

# ===========================================
# REQUIRED: Database (Supabase)
# ===========================================
# Use Transaction Mode Pooler (port 6543) for connection pooling
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true

# For migrations, use Session Mode (port 5432) or direct connection
DATABASE_MIGRATION_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ===========================================
# REQUIRED: Redis (Upstash)
# ===========================================
REDIS_URL=redis://default:[PASSWORD]@[ENDPOINT]:6379
CELERY_BROKER_URL=redis://default:[PASSWORD]@[ENDPOINT]:6379/0
CELERY_RESULT_BACKEND=redis://default:[PASSWORD]@[ENDPOINT]:6379/1

# ===========================================
# REQUIRED: Security Keys
# ===========================================
# Generate: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-min-64-chars

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# Generate: openssl rand -hex 32
INTERNAL_API_KEY=your-internal-api-key-here

# Generate: openssl rand -hex 16
INTERNAL_METRICS_TOKEN=your-metrics-token-here

# ===========================================
# REQUIRED: API Keys
# ===========================================
# OpenAI or other LLM provider
OPENAI_API_KEY=sk-your-key-here

# Supabase
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram (for notifications)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email (Resend)
RESEND_API_KEY=re_your-key-here
FROM_EMAIL=Graxia <hello@yourdomain.com>

# ===========================================
# APP CONFIGURATION
# ===========================================
APP_ENV=production
APP_HOST=graxia-api.fly.dev
APP_BASE_URL=https://graxia-api.fly.dev
FRONTEND_URL=https://your-frontend.vercel.app

# CORS (add your Vercel domain)
ALLOWED_CORS_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com

# ===========================================
# FEATURE FLAGS
# ===========================================
GRAXIA_ENABLED=true
AUTOPILOT_ENABLED=false
LEADGEN_ENABLED=true

# ===========================================
# MONITORING
# ===========================================
SENTRY_DSN=https://your-sentry-dsn-here
LOG_LEVEL=INFO
